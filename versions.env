# Pinned upstream versions for reproducible LGPL static FFmpeg builds.
#
# Everything here is sourced by the build scripts (scripts/*.sh, *.ps1) and the
# CI workflow. Bump a pin here, tag a release, and CI rebuilds every target.
#
# NOTE: the refs below are starting points — confirm each against the FFmpeg 8.1
# API that our rsmpeg pin expects before the first real release, then move every
# ref to an exact tag or commit SHA (no moving branches in a release build).

# --- FFmpeg itself -----------------------------------------------------------
# Must match the API targeted by rsmpeg's `ffmpeg8` feature in the main repo
# (crates/tether-codec/Cargo.toml, rev 4dcf6be... = FFmpeg 8.1 support).
FFMPEG_REPO="https://github.com/FFmpeg/FFmpeg.git"
FFMPEG_REF="n8.1"

# --- Windows-only hardware-encoder headers/dispatchers -----------------------
# nvenc: header-only; FFmpeg dlopens nvEncodeAPI64.dll / nvcuvid.dll at runtime.
NV_CODEC_HEADERS_REPO="https://github.com/FFmpeg/nv-codec-headers.git"
NV_CODEC_HEADERS_REF="n13.0.19.0"

# amf: header-only; FFmpeg dlopens amfrt64.dll at runtime.
AMF_REPO="https://github.com/GPUOpen-LibrariesAndSDKs/AMF.git"
AMF_REF="v1.4.35"

# qsv: the oneVPL *dispatcher* (libvpl). Built static; the actual runtime is
# loaded from the Intel driver at runtime.
LIBVPL_REPO="https://github.com/intel/libvpl.git"
LIBVPL_REF="v2.13.0"

# Human-readable version stamped into artifact names. Bump on every release.
TETHER_FFMPEG_VERSION="8.1.0-tether.1"
