# Pinned upstream versions for reproducible LGPL static FFmpeg builds.
#
# Everything here is sourced by the build scripts (scripts/*.sh, *.ps1) and the
# CI workflow. Bump a pin here, tag a release, and CI rebuilds every target.
#
# NOTE: the refs below are starting points — confirm each against the FFmpeg 8.1
# API that our rsmpeg pin expects before the first real release, then move every
# ref to an exact tag or commit SHA (no moving branches in a release build).

# --- FFmpeg itself -----------------------------------------------------------
# Must match the API targeted by rsmpeg's `ffmpeg8` feature in the main repo
# (crates/tether-codec/Cargo.toml, rev 4dcf6be... = FFmpeg 8.1 support).
FFMPEG_REPO="https://github.com/FFmpeg/FFmpeg.git"
FFMPEG_REF="n8.1"

# --- Windows-only hardware-encoder headers/dispatchers -----------------------
# nvenc: header-only; FFmpeg dlopens nvEncodeAPI64.dll / nvcuvid.dll at runtime.
NV_CODEC_HEADERS_REPO="https://github.com/FFmpeg/nv-codec-headers.git"
NV_CODEC_HEADERS_REF="n13.0.19.0"

# amf: header-only; FFmpeg dlopens amfrt64.dll at runtime.
# FFmpeg 8.1's configure requires AMF >= 1.4.36 (its AMF/core/Version.h check is
# AMF_VERSION >= 0x0001000400240000 = 1.4.36.0); 1.4.35 fails as "amf not found".
AMF_REPO="https://github.com/GPUOpen-LibrariesAndSDKs/AMF.git"
AMF_REF="v1.4.36"

# qsv: the oneVPL *dispatcher* (libvpl). Built static; the actual runtime is
# loaded from the Intel driver at runtime.
LIBVPL_REPO="https://github.com/intel/libvpl.git"
LIBVPL_REF="v2.13.0"

# --- Opus audio codec (software; built static on every target) ---------------
# BSD-licensed → LGPL-compatible, so it stays within our LGPL-only invariant with
# no --enable-nonfree. Built from source as a static lib (CMake) and installed into
# the same prefix FFmpeg installs to; FFmpeg's configure finds it via opus.pc.
# Gives the high-quality libopus encoder/decoder — FFmpeg's *native* opus encoder
# is experimental/lower quality. Unlike the vendor encoders above, Opus is software
# and is built on ALL targets (every os/arch), not Windows-x86_64 only.
LIBOPUS_REPO="https://github.com/xiph/opus.git"
# latest stable, released 2025-12-15. Keep the value bare (no trailing comment):
# scripts/versions.ps1 strips only surrounding quotes, so an inline comment would
# leak into $env:LIBOPUS_REF and break the Windows git checkout.
LIBOPUS_REF="v1.6"

# Human-readable version stamped into artifact names. Bump on every release.
# tether.4: Opus audio (libopus) is now built static from source on every target
# and enabled via --enable-libopus, adding high-quality Opus encode/decode. This
# is the first software codec in the build (everything else is hardware video).
# tether.3: macOS configure now passes --disable-xlib --disable-libxcb so the
# build no longer auto-detects the runner's Homebrew libx11/libxcb and bakes
# `-L/opt/homebrew/Cellar/... -lX11 -lxcb*` into the .pc files. The macOS
# artifact is now OS-framework-only and links without any Homebrew packages.
# tether.2: Windows C++ TUs (gfxcapture's vsrc_gfxcapture_winrt.cpp) now build
# with -MD like the C objects, so the static .lib are uniformly dynamic-CRT and
# link cleanly into the Rust msvc toolchain (was: lone /MT object → LNK2038).
TETHER_FFMPEG_VERSION="8.1.0-tether.4"
